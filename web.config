<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <rule name="Next.js" stopProcessing="true">
          <match url=".*" />
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- QUAN TRỌNG: tránh check sai charset -->
    <httpProtocol>
      <customHeaders>
        <remove name="Content-Type" />
      </customHeaders>
    </httpProtocol>

  </system.webServer>
</configuration>